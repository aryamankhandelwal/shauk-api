# Copy to .env.local and fill in values.
# Add all of these to Vercel Dashboard → Settings → Environment Variables too.

# Supabase — Settings → API in your Supabase project
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # Keep secret — never expose to client

# Gemini (Phase 2) — console.cloud.google.com
GEMINI_API_KEY=

# Google Custom Search (Phase 2) — console.cloud.google.com
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Puppeteer microservice (Phase 2) — your Render service URL
SCREENSHOT_SERVICE_URL=
SCREENSHOT_API_KEY=
